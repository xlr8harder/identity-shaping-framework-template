# LLM Provider API Keys
# Uncomment and fill in the keys for your provider(s)
#
# Tinker (required for training, can also be used for inference)
# TINKER_API_KEY=...

# OpenRouter (recommended for convenient inference)
# OPENROUTER_API_KEY=sk-or-...

# Local OpenAI-compatible inference servers such as vLLM or llama.cpp
# LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
# LOCAL_LLM_API_KEY=...

# Other API providers are also supported, see llm_client repo and docs for details.
#
# Example: OpenAI (optional, for OpenAI models directly)
# OPENAI_API_KEY=sk-...
